---
const supportAreas = [
	"Konflikter, grænser og hverdagssituationer",
	"Barnets følelser, adfærd og signaler",
	"Samarbejde mellem forældre, institution og skole",
	"Tryghed i det nye eller kommende forældreskab",
	"Kulturelle forskelle og familieliv i Danmark",
	"Konkrete redskaber, der kan bruges med det samme",
];

const processSteps = [
	{
		title: "Vi starter med jeres situation",
		text: "Jeg lytter til det, der fylder, og hjælper jer med at få øje på mønstre, behov og handlemuligheder.",
	},
	{
		title: "I får faglig sparring og konkrete redskaber",
		text: "Samtalerne tager udgangspunkt i relationer, tilknytning, mentalisering og barnets følelsesmæssige behov.",
	},
	{
		title: "Små justeringer bliver til ny retning",
		text: "Målet er mere ro, større forståelse og et familieliv, hvor både børn og voksne føler sig bedre hjulpet.",
	},
];

const trustSignals = [
	"25+ års erfaring",
	"Østerbro og online",
	"Familier, skoler og institutioner",
];

const practicePoints = [
	"Tilknytning",
	"Mentalisering",
	"Tryghedscirklen",
	"Se Barnet Indefra",
];
---

<html lang="da">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta
			name="description"
			content="Familievejledning på Østerbro og online med Maria Baad. Faglig, kærlig og konkret støtte til familier og institutioner."
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Maria Baad | Familievejledning</title>
	</head>
	<body>
		<a class="skip-link" href="#indhold">Spring til indhold</a>
		<header class="site-header">
			<a class="brand" href="/" aria-label="Maria Baad forside">
				<span class="brand-mark">MB</span>
				<span>
					<strong>Maria Baad</strong>
					<small>Familievejledning</small>
				</span>
			</a>
			<nav class="main-nav" aria-label="Primær navigation">
				<a href="#familier">Familier</a>
				<a href="#institutioner">Institutioner</a>
				<a href="#om">Om mig</a>
				<a href="#kontakt">Kontakt</a>
			</nav>
		</header>

		<main id="indhold">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow">Familievejledning på Østerbro og online</p>
					<h1 id="hero-title">Tryg støtte til familier, der ønsker mere ro, retning og forståelse</h1>
					<p class="hero-lede">
						Jeg tilbyder familiestøtte og vejledning med et kærligt, fordomsfrit og
						fagligt stærkt udgangspunkt. Sammen finder vi konkrete veje videre i hverdagen.
					</p>
					<div class="hero-actions" aria-label="Vigtige handlinger">
						<a class="button primary" href="#kontakt">Kontakt mig</a>
						<a class="button secondary" href="#saadan">Se hvordan det foregår</a>
					</div>
					<ul class="trust-list" aria-label="Nøgletal">
						{trustSignals.map((signal) => <li>{signal}</li>)}
					</ul>
				</div>
				<div class="hero-media" aria-label="Kort om mig">
					<div class="portrait-panel">
						<div class="portrait-mark" aria-hidden="true">MB</div>
						<div class="portrait-card">
							<span>Maria Baad Andersen</span>
							<strong>Familievejleder med blik for både barnets behov og de voksnes handlemuligheder.</strong>
						</div>
					</div>
				</div>
			</section>

			<section class="audiences" aria-label="Målgrupper">
				<a class="audience-card" id="familier" href="#hjaelp">
					<span>For familier</span>
					<strong>Hjælp til konflikter, trivsel, samarbejde og svære følelser.</strong>
				</a>
				<a class="audience-card institution" id="institutioner" href="#institutioner-indhold">
					<span>For institutioner</span>
					<strong>Praksisnære forløb om Tryghedscirklen, mentalisering og børns behov.</strong>
				</a>
			</section>

			<section class="section split" id="hjaelp" aria-labelledby="help-title">
				<div>
					<p class="eyebrow">Hvordan jeg kan hjælpe</p>
					<h2 id="help-title">Når familielivet kalder på nye handlemuligheder</h2>
					<p>
						Forældreskab kan føles både kærligt, overvældende og svært at navigere i.
						Jeg hjælper jer med at forstå, hvad der kan ligge bag barnets reaktioner, og
						hvordan I som voksne kan møde barnet med mere tryghed.
					</p>
				</div>
				<ul class="support-list" aria-label="Temaer jeg kan hjælpe med">
					{supportAreas.map((area) => <li>{area}</li>)}
				</ul>
			</section>

			<section class="section process" id="saadan" aria-labelledby="process-title">
				<p class="eyebrow">Sådan foregår et forløb</p>
				<h2 id="process-title">Et trygt rum med plads til både sårbarhed og konkrete løsninger</h2>
				<div class="process-grid">
					{processSteps.map((step, index) => (
						<article class="step">
							<span>{String(index + 1).padStart(2, "0")}</span>
							<h3>{step.title}</h3>
							<p>{step.text}</p>
						</article>
					))}
				</div>
			</section>

			<section class="section about" id="om" aria-labelledby="about-title">
				<div class="about-media" aria-label="Mit faglige fundament">
					<div class="practice-panel">
						<span class="practice-kicker">Fagligt fundament</span>
						<ul>
							{practicePoints.map((point) => <li>{point}</li>)}
						</ul>
					</div>
				</div>
				<div class="about-copy">
					<p class="eyebrow">Hvem er jeg?</p>
					<h2 id="about-title">Erfaren pædagog og familievejleder med blik for hele familien</h2>
					<p>
						Jeg har over 25 års erfaring med børn, familier og relationer. Jeg arbejder
						tæt sammen med familier, der ønsker at skabe mere forståelse, glæde og håb i
						hverdagen.
					</p>
					<p>
						Mit faglige fundament bygger blandt andet på tilknytning, mentalisering,
						Tryghedscirklen og praksisnære redskaber, der kan bruges i familieliv,
						daginstitutioner og skoler.
					</p>
				</div>
			</section>

			<section class="quote-band" aria-labelledby="quote-title">
				<div>
					<p class="eyebrow">Anbefaling</p>
					<h2 id="quote-title">Familier fremhæver varme, faglighed og konkret hjælp</h2>
				</div>
				<blockquote>
					"Maria forstod at italesætte de udfordringer vi oplevede fra barnets perspektiv
					med stor faglighed og en sødme der oser af kærlighed til børn og unge."
					<cite>Susanne, mor til piger på 1 og 4 år</cite>
				</blockquote>
			</section>

			<section class="section institution-section" id="institutioner-indhold" aria-labelledby="institution-title">
				<div>
					<p class="eyebrow">Til daginstitutioner og kommuner</p>
					<h2 id="institution-title">Tryghed i praksis for personalegrupper</h2>
					<p>
						Jeg tilbyder kompetenceudvikling og praksisnære forløb med afsæt i
						Tryghedscirklen og Se Barnet Indefra. Formålet er at skabe et fælles sprog og
						styrke personalets blik for barnets behov bag adfærd.
					</p>
				</div>
				<div class="feature-panel">
					<h3>Forløb kan indeholde</h3>
					<ul>
						<li>Introduktion til centrale begreber</li>
						<li>Refleksionsøvelser fra egen praksis</li>
						<li>Fokus på den voksnes rolle som tryg base</li>
						<li>Anbefalinger til det videre arbejde</li>
					</ul>
				</div>
			</section>

			<section class="contact-section" id="kontakt" aria-labelledby="contact-title">
				<div>
					<p class="eyebrow">Kontakt</p>
					<h2 id="contact-title">Vil du høre, om jeg kan hjælpe jer?</h2>
					<p>
						Du er velkommen til at ringe, sende en SMS eller skrive en e-mail. Jeg
						tilbyder samtaler hjemme, online eller på kontor på Østerbro.
					</p>
				</div>
				<div class="contact-actions">
					<a class="button primary" href="tel:+4593901154">Ring til mig</a>
					<a class="button secondary" href="mailto:kontaktmariabaad@gmail.com">Skriv e-mail</a>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<p>Maria Baad</p>
			<p>Telefon: <a href="tel:+4593901154">+45 93901154</a></p>
			<p>CVR: 45155099</p>
		</footer>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--paper: #faf6ef;
		--surface: #fffdf8;
		--ink: #1f2d2a;
		--muted: #5f6f69;
		--sage: #dce8df;
		--sage-soft: #edf4ee;
		--sage-dark: #31564e;
		--clay: #a95d4c;
		--clay-soft: #f2ddd5;
		--butter: #f2d88f;
		--sky: #d9e8ec;
		--rose: #ead7d3;
		--white: #fffdf8;
		--line: rgba(34, 48, 43, 0.14);
		--shadow: 0 22px 55px rgba(34, 48, 43, 0.1);
		--shadow-soft: 0 14px 32px rgba(34, 48, 43, 0.08);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: 96px;
	}

	body {
		margin: 0;
		background: var(--paper);
		color: var(--ink);
		font-size: 16px;
		line-height: 1.6;
	}

	a {
		color: inherit;
	}

	:focus-visible {
		outline: 3px solid var(--clay);
		outline-offset: 4px;
	}

	.skip-link {
		position: fixed;
		top: 12px;
		left: 12px;
		z-index: 100;
		transform: translateY(-140%);
		padding: 10px 14px;
		background: var(--ink);
		border-radius: 7px;
		color: var(--white);
		font-weight: 800;
		text-decoration: none;
		transition: transform 180ms ease;
	}

	.skip-link:focus-visible {
		transform: translateY(0);
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 18px clamp(20px, 5vw, 72px);
		background:
			linear-gradient(180deg, rgba(237, 244, 238, 0.94), rgba(255, 253, 248, 0.9)),
			rgba(255, 253, 248, 0.9);
		border-bottom: 1px solid rgba(34, 48, 43, 0.18);
		box-shadow: 0 8px 22px rgba(34, 48, 43, 0.045);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 44px;
		height: 44px;
		place-items: center;
		border-radius: 50%;
		background: linear-gradient(145deg, var(--sage-dark), #243e39);
		color: var(--white);
		font-weight: 700;
		box-shadow: var(--shadow-soft);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand small,
	.eyebrow {
		color: var(--muted);
		font-size: 0.84rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.main-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 8px 22px;
		font-size: 0.95rem;
	}

	.main-nav a {
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		text-underline-offset: 5px;
	}

	.main-nav a:hover,
	.main-nav a:focus-visible {
		color: var(--clay);
	}

	main {
		overflow: hidden;
	}

	.hero,
	.section,
	.quote-band,
	.contact-section,
	.site-footer {
		padding-inline: clamp(20px, 5vw, 72px);
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.78fr);
		gap: clamp(36px, 7vw, 92px);
		align-items: center;
		min-height: min(780px, calc(100dvh - 82px));
		padding-block: clamp(58px, 8vw, 92px) clamp(44px, 6vw, 72px);
		background:
			linear-gradient(180deg, rgba(220, 232, 223, 0.62), rgba(250, 246, 239, 0) 34%),
			linear-gradient(115deg, rgba(220, 232, 223, 0.78), transparent 50%),
			linear-gradient(22deg, rgba(217, 232, 236, 0.56), transparent 44%),
			var(--paper);
	}

	.eyebrow {
		margin: 0 0 14px;
		letter-spacing: 0;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.08;
		letter-spacing: 0;
	}

	h1 {
		max-width: 880px;
		margin-bottom: 22px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(3rem, 7.4vw, 6.35rem);
		font-weight: 500;
	}

	h2 {
		max-width: 780px;
		margin-bottom: 20px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(2.15rem, 4.6vw, 4.6rem);
		font-weight: 500;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 1.2rem;
	}

	.hero-lede,
	.section p,
	.contact-section p {
		max-width: 680px;
		color: var(--muted);
		font-size: 1.08rem;
	}

	.hero-actions,
	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 30px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		min-height: 48px;
		padding: 13px 20px;
		border: 1px solid transparent;
		border-radius: 7px;
		font-weight: 800;
		text-decoration: none;
		box-shadow: 0 0 0 rgba(34, 48, 43, 0);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
		touch-action: manipulation;
	}

	.button:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-soft);
	}

	.button.primary {
		background: var(--sage-dark);
		color: var(--white);
	}

	.button.secondary {
		background: var(--white);
		border-color: var(--line);
		color: var(--sage-dark);
	}

	.button.primary::after,
	.button.secondary::after {
		content: "";
		width: 0.58em;
		height: 0.58em;
		border-top: 2px solid currentColor;
		border-right: 2px solid currentColor;
		transform: rotate(45deg);
	}

	.trust-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 28px 0 0;
		padding: 0;
		list-style: none;
	}

	.trust-list li {
		padding: 9px 12px;
		background: rgba(255, 253, 248, 0.72);
		border: 1px solid var(--line);
		border-radius: 999px;
		color: var(--sage-dark);
		font-size: 0.9rem;
		font-weight: 800;
	}

	.hero-media,
	.about-media {
		min-width: 0;
	}

	.portrait-panel {
		position: relative;
		display: flex;
		min-height: 560px;
		align-items: end;
		justify-content: center;
		overflow: hidden;
		aspect-ratio: 4 / 5;
		background:
			linear-gradient(150deg, rgba(255, 253, 248, 0.42), rgba(242, 221, 213, 0.22) 45%, rgba(217, 232, 236, 0.5)),
			var(--sage);
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: var(--shadow);
	}

	.portrait-panel::before {
		position: absolute;
		inset: 10%;
		content: "";
		background:
			linear-gradient(180deg, rgba(49, 86, 78, 0.08), rgba(49, 86, 78, 0.28)),
			linear-gradient(135deg, var(--surface), var(--rose));
		border: 1px solid rgba(49, 86, 78, 0.14);
		border-radius: 999px 999px 8px 8px;
	}

	.portrait-mark {
		position: relative;
		display: grid;
		width: min(62%, 280px);
		aspect-ratio: 1;
		margin-bottom: 118px;
		place-items: center;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 50%;
		color: var(--sage-dark);
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(4rem, 9vw, 7.2rem);
		box-shadow: var(--shadow-soft);
	}

	.portrait-card {
		position: absolute;
		right: clamp(16px, 4vw, 32px);
		bottom: clamp(16px, 4vw, 32px);
		left: clamp(16px, 4vw, 32px);
		display: grid;
		gap: 8px;
		padding: 20px;
		background: rgba(255, 253, 248, 0.9);
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: var(--shadow-soft);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
	}

	.portrait-card span,
	.practice-kicker {
		color: var(--clay);
		font-size: 0.82rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.portrait-card strong {
		max-width: 32ch;
		font-size: 1.05rem;
		line-height: 1.34;
	}

	.audiences {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-block: 1px solid var(--line);
	}

	.audience-card {
		display: grid;
		gap: 12px;
		min-height: 210px;
		padding: clamp(24px, 4vw, 52px);
		background: var(--white);
		text-decoration: none;
		transition:
			background-color 180ms ease,
			transform 180ms ease;
	}

	.audience-card:hover {
		background: var(--clay-soft);
	}

	.audience-card + .audience-card {
		border-left: 1px solid var(--line);
	}

	.audience-card span {
		color: var(--clay);
		font-weight: 800;
	}

	.audience-card strong {
		max-width: 620px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.55rem, 3vw, 2.55rem);
		font-weight: 500;
		line-height: 1.15;
	}

	.audience-card.institution {
		background: var(--sage);
	}

	.section {
		padding-block: clamp(70px, 10vw, 132px);
	}

	.split,
	.about,
	.institution-section,
	.contact-section {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
		gap: clamp(32px, 6vw, 76px);
		align-items: start;
	}

	.support-list,
	.feature-panel ul {
		display: grid;
		gap: 12px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.support-list li,
	.feature-panel li {
		position: relative;
		padding: 16px 18px;
		padding-left: 48px;
		background: var(--white);
		border: 1px solid var(--line);
		border-radius: 8px;
	}

	.support-list li::before,
	.feature-panel li::before {
		position: absolute;
		top: 20px;
		left: 18px;
		width: 14px;
		height: 8px;
		content: "";
		border-bottom: 2px solid var(--sage-dark);
		border-left: 2px solid var(--sage-dark);
		transform: rotate(-45deg);
	}

	.process {
		background: var(--white);
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: 34px;
	}

	.step {
		min-height: 300px;
		padding: 28px;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 1px 0 rgba(34, 48, 43, 0.05);
	}

	.step span {
		display: inline-block;
		margin-bottom: 48px;
		color: var(--clay);
		font-weight: 900;
	}

	.step p {
		color: var(--muted);
	}

	.about {
		align-items: center;
	}

	.practice-panel {
		display: grid;
		gap: 24px;
		min-height: 360px;
		align-content: center;
		padding: clamp(26px, 5vw, 48px);
		background:
			linear-gradient(135deg, rgba(255, 253, 248, 0.76), rgba(217, 232, 236, 0.56)),
			var(--sage-soft);
		border: 1px solid var(--line);
		border-radius: 8px;
	}

	.practice-panel ul {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2px 28px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.practice-panel li {
		position: relative;
		min-height: 0;
